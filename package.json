{
  "name": "adb-intranet",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:dev": "ng serve --configuration dev",
    "build": "rimraf dist && ng lint && ng build",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "lint:strict": "ng lint --max-warnings 0",
    "build:local": "rimraf dist && ng lint && ng build --configuration local",
    "build:dev": "rimraf dist && ng lint && ng build --configuration dev",
    "build:qa": "rimraf dist && ng lint && ng build --configuration qa",
    "build:uat": "rimraf dist && ng lint && ng build --configuration uat",
    "build:prod": "rimraf dist && ng lint && ng build --configuration production",
    "watch": "ng build --watch --configuration local",
    "watch:dev": "ng build --watch --configuration dev",
    "test": "ng test",
    "test:ci": "rimraf coverage && ng test --watch=false --browsers=ChromeHeadlessCI",
    "test:coverage": "rimraf coverage && ng test --watch=false --browsers=ChromeHeadlessCI --code-coverage",
    "test:coverage:watch": "rimraf coverage && ng test --code-coverage"
  },
  "private": true,
  "packageManager": "npm@11.15.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@tabler/icons-angular": "^3.44.0",
    "@azure/msal-angular": "^5.3.1",
    "@azure/msal-browser": "^5.16.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.18",
    "@angular-eslint/builder": "^21.4.0",
    "@angular-eslint/eslint-plugin": "^21.4.0",
    "@angular-eslint/eslint-plugin-template": "^21.4.0",
    "@angular-eslint/schematics": "^21.4.0",
    "@angular-eslint/template-parser": "^21.4.0",
    "@angular/build": "^21.2.12",
    "@angular/cli": "^21.2.12",
    "@angular/compiler-cli": "^21.2.0",
    "@types/jasmine": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^9.39.4",
    "jasmine-core": "^6.3.0",
    "jsdom": "^28.0.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
